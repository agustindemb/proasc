---
const pathname = Astro.url.pathname;
const isHome = pathname === '/';

const getLink = (hash: string) => {
  return isHome ? hash : `/${hash}`;
};
---

<footer>
  <div class="container footer-grid">
    <!-- Column 1: Branding & Contact Info (EEAT) -->
    <div class="footer-brand">
      <a href={isHome ? "#hero" : "/"} class="logo" style="margin-bottom: 1rem; display: inline-flex;" id="footer-logo">
        <img src="/logo.jpeg" alt="Logo de ASC Automations" class="logo-img" width="30" height="30">
        <span class="logo-text">proasc</span>
      </a>
      <p style="margin-bottom: 1.5rem;">ASC (Automation System Company) se especializa en asistentes conversacionales de IA, automatización para WhatsApp de empresas e integraciones de backend.</p>
      
      <!-- Visible Contact Info for EEAT -->
      <div class="footer-contact-info" style="font-size: 0.85rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 0.5rem;">
        <div><i class="fa-solid fa-envelope" style="color: var(--primary); margin-right: 0.5rem; width: 15px;"></i> <a href="mailto:ventas@proasc.com" style="color: inherit; text-decoration: none;">ventas@proasc.com</a></div>
        <div><i class="fa-solid fa-phone" style="color: var(--primary); margin-right: 0.5rem; width: 15px;"></i> <a href="https://wa.me/5491138927598" style="color: inherit; text-decoration: none;">+54 9 11 3892-7598</a></div>
        <div><i class="fa-solid fa-location-dot" style="color: var(--primary); margin-right: 0.5rem; width: 15px;"></i> Buenos Aires, Argentina</div>
      </div>
    </div>
    
    <!-- Column 2: Navigation -->
    <div class="footer-links-col">
      <h4>Navegación</h4>
      <ul class="footer-links">
        <li><a href={getLink('#hero')}>Inicio</a></li>
        <li><a href={getLink('#whatsapp-demo')}>Demo Chatbot</a></li>
        <li><a href={getLink('#services')}>Servicios</a></li>
        <li><a href={getLink('#workflow')}>Nuestro Flujo</a></li>
        <li><a href={getLink('#about')}>Sobre ASC</a></li>
        <li><a href="/precios">Precios y Planes</a></li>
        <li><a href="/blog">Blog de IA</a></li>
      </ul>
    </div>

    <!-- Column 3: Compañía & Legal (EEAT) -->
    <div class="footer-links-col">
      <h4>Compañía</h4>
      <ul class="footer-links">
        <li><a href="/sobre-nosotros" style="font-weight: 500;">Sobre Nosotros</a></li>
        <li><a href="/politica-privacidad">Política de Privacidad</a></li>
        <li><a href="/terminos-condiciones">Términos y Condiciones</a></li>
        <li><a href={getLink('#contact')}>Solicitar Presupuesto</a></li>
      </ul>
    </div>
    
    <!-- Column 4: Newsletter -->
    <div class="footer-newsletter">
      <h4>Novedades</h4>
      <p>Suscríbete para recibir plantillas de automatización y consejos de IA quincenales directamente en tu correo.</p>
      <form class="newsletter-form" id="subscribe-newsletter-form">
        <input type="email" class="newsletter-input" placeholder="correo@empresa.com" required id="newsletter-email-input">
        <button type="submit" class="btn btn-primary btn-newsletter" id="newsletter-submit-btn">
          Unirse
        </button>
      </form>
    </div>
  </div>
  
  <div class="container footer-bottom">
    <p>&copy; {new Date().getFullYear()} ASC (Automation System Company). Todos los derechos reservados.</p>
    <div class="social-links">
      <a href="https://linkedin.com" target="_blank" class="social-link" id="social-lnk-linkedin" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
      <a href="https://www.instagram.com/asc.automations/" target="_blank" class="social-link" id="social-lnk-instagram" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
      <a href="https://github.com" target="_blank" class="social-link" id="social-lnk-github" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
    </div>
  </div>
</footer>
