---
const pathname = Astro.url.pathname;
const isHome = pathname === '/';

// Helpers to return correct URLs depending on current page
const getLink = (hash: string) => {
  return isHome ? hash : `/${hash}`;
};
---

<header id="main-header">
  <div class="container nav-container">
    <a href={isHome ? "#hero" : "/"} class="logo" id="logo-brand">
      <!-- logo.jpeg from root /public folder serves as /logo.jpeg in Astro -->
      <img src="/logo.jpeg" alt="Logo de ASC Automations" class="logo-img" width="40" height="40">
      <span class="logo-text">proasc</span>
    </a>
    
    <ul class="nav-menu" id="navigation-menu">
      <li><a href={getLink('#hero')} class="nav-link">Inicio</a></li>
      <li><a href={getLink('#whatsapp-demo')} class="nav-link">Demo Chatbot</a></li>
      <li><a href={getLink('#services')} class="nav-link">Servicios</a></li>
      <li><a href={getLink('#workflow')} class="nav-link">Nuestro Flujo</a></li>
      <li><a href={getLink('#about')} class="nav-link">Sobre ASC</a></li>
      <li><a href="/precios" class={`nav-link ${pathname === '/precios' ? 'nav-link-active' : ''}`} style={pathname === '/precios' ? 'color: var(--primary);' : ''}>Precios</a></li>
      <li><a href="/blog" class={`nav-link ${pathname.startsWith('/blog') ? 'nav-link-active' : ''}`} style={pathname.startsWith('/blog') ? 'color: var(--primary);' : ''}>Blog</a></li>
      <li><a href={getLink('#contact')} class="nav-link">Contacto</a></li>
    </ul>
    
    <a href={getLink('#contact')} class="nav-cta" id="nav-cta-btn">Crear Mi Sistema</a>
    
    <button class="mobile-nav-toggle" id="mobile-menu-toggle" aria-label="Toggle Menu">
      <i class="fa-solid fa-bars"></i>
    </button>
  </div>
</header>
