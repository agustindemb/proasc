---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog');
// Sort by publishDate descending
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime();
});

const breadcrumbs = [
  { name: "Inicio", url: "/" },
  { name: "Blog", url: "/blog" }
];
---

<Layout
  title="Blog de IA y Automatización para Negocios | proasc"
  description="Aprende cómo implementar asistentes virtuales, configurar la API de WhatsApp, integrar CRMs y automatizar procesos con n8n y modelos de Inteligencia Artificial."
  seoType="WebPage"
  breadcrumbs={breadcrumbs}
>
  <!-- Hero Section -->
  <section style="padding-top: 140px; padding-bottom: 3rem; text-align: center;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 2rem;">
        <span class="section-subtitle">Recursos y Guías</span>
        <h1 class="section-title">Blog de Automatización</h1>
        <p class="section-desc">Artículos técnicos, tutoriales paso a paso y mejores prácticas para escalar operaciones con Inteligencia Artificial.</p>
      </div>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section style="padding-top: 0; padding-bottom: 6rem;">
    <div class="container">
      {sortedPosts.length === 0 ? (
        <div style="text-align: center; padding: 4rem 0; color: var(--text-muted);">
          <i class="fa-solid fa-folder-open" style="font-size: 3rem; margin-bottom: 1rem; color: var(--border);"></i>
          <p>Próximamente publicaremos nuestros primeros artículos. ¡Vuelve pronto!</p>
        </div>
      ) : (
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2.5rem;">
          {sortedPosts.map((post) => (
            <article class="glass-card" style="padding: 0; border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; height: 100%; border-color: rgba(255,255,255,0.06); transition: transform 0.3s, border-color 0.3s;" onmouseover="this.style.transform='translateY(-5px)'; this.style.borderColor='var(--primary)'" onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(255,255,255,0.06)'">
              
              <!-- Post Image (fallback if none) -->
              <div style="height: 180px; width: 100%; background: linear-gradient(135deg, rgba(0, 242, 254, 0.05), rgba(155, 81, 224, 0.05)); position: relative; border-bottom: 1px solid rgba(255,255,255,0.05);">
                {post.data.image ? (
                  <img src={post.data.image} alt={post.data.title} style="width: 100%; height: 100%; object-fit: cover;" loading="lazy">
                ) : (
                  <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.15); font-size: 3rem;">
                    <i class="fa-solid fa-code"></i>
                  </div>
                )}
                
                {post.data.category && (
                  <span style="position: absolute; top: 15px; left: 15px; background: linear-gradient(90deg, var(--primary), var(--secondary)); color: #030712; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; padding: 0.25rem 0.75rem; border-radius: 50px; letter-spacing: 0.5px;">
                    {post.data.category}
                  </span>
                )}
              </div>

              <!-- Post Info Content -->
              <div style="padding: 1.8rem; display: flex; flex-direction: column; flex: 1; justify-content: space-between; gap: 1rem;">
                <div>
                  <div style="display: flex; gap: 1rem; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.75rem;">
                    <span><i class="fa-regular fa-calendar" style="margin-right: 0.25rem;"></i> {post.data.publishDate}</span>
                    <span><i class="fa-regular fa-user" style="margin-right: 0.25rem;"></i> {post.data.author}</span>
                  </div>
                  
                  <h2 style="color: #fff; font-size: 1.25rem; font-weight: 700; line-height: 1.4; margin-bottom: 0.75rem; font-family: 'Space Grotesk', sans-serif;">
                    <a href={`/blog/${post.slug}`} style="color: inherit; text-decoration: none;">{post.data.title}</a>
                  </h2>
                  
                  <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.5; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                    {post.data.description}
                  </p>
                </div>

                <div style="padding-top: 1rem; border-top: 1px solid rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: space-between;">
                  <a href={`/blog/${post.slug}`} style="color: var(--primary); text-decoration: none; font-size: 0.85rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.25rem;">
                    Leer más <i class="fa-solid fa-arrow-right" style="font-size: 0.75rem;"></i>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
