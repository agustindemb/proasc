---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const data = entry.data;

// Render Markdown Content and extract Headings
const { Content, headings } = await entry.render();

// Calculate word count and reading time
const wordCount = entry.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Filter H2 and H3 headings for the TOC
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

// Fetch related posts (by matching tags)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.slug !== entry.slug && p.data.tags.some(tag => data.tags.includes(tag)))
  .slice(0, 3); // max 3 related posts

const breadcrumbs = [
  { name: "Inicio", url: "/" },
  { name: "Blog", url: "/blog" },
  { name: data.title, url: `/blog/${entry.slug}` }
];

// Blog Schema Metadata
const blogSchemaData = {
  title: data.title,
  description: data.description,
  publishDate: data.publishDate,
  updateDate: data.updateDate || data.publishDate,
  author: data.author,
  authorLinkedin: data.authorLinkedin,
  image: data.image
};
---

<Layout
  title={data.title}
  description={data.description}
  seoType="BlogPosting"
  schemaData={blogSchemaData}
  breadcrumbs={breadcrumbs}
  conversionGoal="submit-form"
>
  <div class="container blog-layout-container">
    
    <!-- Main Article Body -->
    <article style="min-width: 0;">
      
      <!-- Article Metadata Header -->
      <header style="margin-bottom: 2.5rem; text-align: left;">
        {data.category && (
          <span style="background: linear-gradient(90deg, var(--primary), var(--secondary)); color: #030712; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; padding: 0.3rem 0.8rem; border-radius: 50px; display: inline-block; margin-bottom: 1rem; letter-spacing: 0.5px;">
            {data.category}
          </span>
        )}
        
        <h1 style="font-family: 'Space Grotesk', sans-serif; font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: 1.5rem; overflow-wrap: break-word; word-break: break-word;">
          {data.title}
        </h1>
        
        <!-- EEAT Author and Update Info -->
        <div style="display: flex; flex-wrap: wrap; gap: 2rem; font-size: 0.9rem; color: var(--text-muted); border-bottom: 1px solid rgba(255,255,255,0.06); padding-bottom: 1.5rem;">
          <div style="display: inline-flex; align-items: center; gap: 0.5rem;">
            <i class="fa-regular fa-user" style="color: var(--primary); font-size: 1rem;"></i>
            <span>Autor:</span>
            {data.authorLinkedin ? (
              <a href={data.authorLinkedin} target="_blank" style="color: #fff; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.35rem; transition: color 0.3s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='#fff'">
                {data.author} <i class="fa-brands fa-linkedin" style="font-size: 0.95rem; color: #0077b5; vertical-align: middle;"></i>
              </a>
            ) : (
              <span style="color: #fff; font-weight: 600;">{data.author}</span>
            )}
          </div>
          
          <div style="display: inline-flex; align-items: center; gap: 0.5rem;">
            <i class="fa-regular fa-calendar" style="color: var(--primary); font-size: 1rem;"></i>
            <span>Publicado:</span>
            <span style="color: #fff; font-weight: 500;">{data.publishDate}</span>
          </div>

          {data.updateDate && data.updateDate !== data.publishDate && (
            <div style="display: inline-flex; align-items: center; gap: 0.5rem;">
              <i class="fa-regular fa-calendar-check" style="color: var(--secondary); font-size: 1rem;"></i>
              <span>Actualizado:</span>
              <span style="color: #fff; font-weight: 500;">{data.updateDate}</span>
            </div>
          )}
          
          <div style="display: inline-flex; align-items: center; gap: 0.5rem;">
            <i class="fa-regular fa-clock" style="color: var(--primary); font-size: 1rem;"></i>
            <span>Lectura:</span>
            <span style="color: #fff; font-weight: 500;">{readingTime} min</span>
          </div>
        </div>
      </header>

      <!-- Post Main Image (contain mode so diagrams & text are never cut off) -->
      {data.image && (
        <div style="border-radius: 16px; overflow: hidden; margin-bottom: 2.5rem; border: 1px solid rgba(255,255,255,0.06); width: 100%; background: rgba(0, 0, 0, 0.2); display: flex; justify-content: center;">
          <img src={data.image} alt={data.imageAlt || data.title} style="width: 100%; height: auto; max-height: 550px; object-fit: contain; display: block;" loading="eager">
        </div>
      )}

      <!-- Rendered Article Markdown Content -->
      <div class="markdown-body">
        <Content />
      </div>

      <!-- Tag Cloud -->
      {data.tags && data.tags.length > 0 && (
        <div style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.05); display: flex; gap: 0.5rem; flex-wrap: wrap;">
          {data.tags.map((tag) => (
            <span style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.05); font-size: 0.8rem; color: var(--text-muted); padding: 0.25rem 0.75rem; border-radius: 50px;">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <!-- Related articles section -->
      {relatedPosts.length > 0 && (
        <div style="margin-top: 4rem; padding-top: 3rem; border-top: 1px solid rgba(255,255,255,0.08);">
          <h3 style="font-family: 'Space Grotesk', sans-serif; font-size: 1.4rem; color: #fff; margin-bottom: 2rem;">Artículos Relacionados</h3>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem;">
            {relatedPosts.map((post) => (
              <div class="glass-card" style="padding: 1.5rem; border-radius: 12px;">
                <span style="font-size: 0.75rem; color: var(--primary);">{post.data.category}</span>
                <h4 style="font-size: 1rem; color: #fff; margin-top: 0.25rem; font-family: 'Space Grotesk', sans-serif; line-height: 1.3;">
                  <a href={`/blog/${post.slug}`} style="color: inherit; text-decoration: none;">{post.data.title}</a>
                </h4>
                <a href={`/blog/${post.slug}`} style="color: var(--primary); font-size: 0.8rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem; margin-top: 1rem;">Ver Post <i class="fa-solid fa-arrow-right" style="font-size: 0.7rem;"></i></a>
              </div>
            ))}
          </div>
        </div>
      )}
    </article>

    <!-- Sidebar with TOC -->
    <aside style="position: sticky; top: 120px; display: flex; flex-direction: column; gap: 2rem;">
      <!-- Table of Contents -->
      {tocHeadings.length > 0 && (
        <div class="glass-card" style="padding: 1.8rem; border-radius: 16px;">
          <h3 style="font-family: 'Space Grotesk', sans-serif; font-size: 1.05rem; color: #fff; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.75rem;">
            <i class="fa-solid fa-list-ol" style="color: var(--primary);"></i> Contenido del Artículo
          </h3>
          <nav aria-label="Table of contents" class="toc-nav">
            <ul>
              {tocHeadings.map((h) => (
                <li class={`toc-item depth-${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      )}
      
      <!-- Mini CTA Box -->
      <div class="glass-card" style="padding: 1.8rem; border-radius: 16px; border-color: rgba(0, 242, 254, 0.15); text-align: center;">
        <h3 style="font-size: 1.1rem; color: #fff; margin-bottom: 0.75rem; font-family: 'Space Grotesk', sans-serif;">¿Necesitas automatización?</h3>
        <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 1.25rem;">Transformamos las tareas manuales repetitivas de tu negocio en sistemas autogestionados.</p>
        <a href="/#contact" class="btn btn-primary" style="font-size: 0.8rem; padding: 0.5rem 1rem; width: 100%; justify-content: center;">Solicitar Presupuesto</a>
      </div>
    </aside>
  </div>
</Layout>

<style is:global>
  /* Markdown styling definitions for standard rendering */
  .markdown-body {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
  }
  
  .markdown-body h2 {
    font-family: 'Space Grotesk', sans-serif;
    color: #fff;
    font-size: 1.6rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 0.5rem;
  }

  .markdown-body h3 {
    font-family: 'Space Grotesk', sans-serif;
    color: #fff;
    font-size: 1.25rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .markdown-body p {
    margin-bottom: 1.5rem;
  }

  .markdown-body ul, .markdown-body ol {
    margin-left: 2rem;
    margin-bottom: 1.5rem;
  }

  .markdown-body li {
    margin-bottom: 0.5rem;
  }

  .markdown-body a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.3s;
  }

  .markdown-body a:hover {
    color: var(--secondary);
  }

  .markdown-body blockquote {
    border-left: 4px solid var(--primary);
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #fff;
    background: rgba(0, 242, 254, 0.02);
    border-radius: 0 8px 8px 0;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }

  /* TOC Sidebar Styles */
  .toc-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .toc-item a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.3s;
    line-height: 1.4;
    display: block;
  }

  .toc-item a:hover {
    color: var(--primary);
  }

  .toc-item.depth-3 {
    padding-left: 1rem;
    border-left: 1px solid rgba(255,255,255,0.05);
  }
  
  /* Responsive breakpoint for sidebar stack */
  @media (max-width: 900px) {
    .blog-layout-container {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }
    aside {
      position: static !important;
    }
  }
</style>
