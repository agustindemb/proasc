---
import Layout from '../layouts/Layout.astro';

// Structured data for products/pricing to pass to schema
const pricingSchemaData = {
  title: "Planes de Automatización proasc",
  description: "Planes y precios de automatización de WhatsApp, agentes conversacionales de Inteligencia Artificial y flujos de backend.",
  brand: "proasc",
  offers: [
    { name: "ASC START", price: "50", currency: "USD" },
    { name: "ASC GROW", price: "120", currency: "USD" },
    { name: "ASC AI", price: "250", currency: "USD" }
  ]
};

const breadcrumbs = [
  { name: "Inicio", url: "/" },
  { name: "Precios", url: "/precios" }
];
---

<Layout 
  title="proasc | Planes y Precios - Sistemas de Automatización" 
  description="Conoce los planes y precios de proasc. Desde soluciones básicas de WhatsApp hasta asistentes con Inteligencia Artificial a medida e integraciones personalizadas."
  seoType="WebPage"
  schemaData={pricingSchemaData}
  breadcrumbs={breadcrumbs}
  conversionGoal="whatsapp-cta"
>
  <!-- Title Banner -->
  <section id="pricing-hero" style="padding-top: 50px; padding-bottom: 2rem; text-align: center;">
    <div class="container">
      <div class="section-header reveal" style="margin-bottom: 2rem;">
        <span class="section-subtitle">Tarifas Transparentes</span>
        <h1 class="section-title">Elige el Plan para tu Negocio</h1>
        <p class="section-desc">Estructuras de precios pensadas para escalar a medida que tu negocio crece. Sin cargos sorpresa.</p>
      </div>
    </div>
  </section>

  <!-- Pricing Cards Section -->
  <section id="pricing-plans" style="padding-top: 0;">
    <div class="container">
      <div class="pricing-grid">
        
        <!-- CARD 1: ASC START -->
        <div class="glass-card pricing-card reveal" id="plan-start">
          <div>
            <h3 style="font-size: 1.6rem; color: #fff;">ASC START</h3>
            <p style="font-size: 0.85rem; color: var(--text-muted); min-height: 48px; margin-top: 0.5rem;">
              Ideal para negocios que reciben consultas repetitivas y quieren profesionalizar su atención.
            </p>
            
            <div class="price-value-container">
              <div class="price-setup">USD 200 Setup</div>
              <div class="price-monthly">USD 50<span>/mes</span></div>
            </div>
            
            <ul class="pricing-features">
              <li><i class="fa-solid fa-check"></i> Configuración de WhatsApp Business</li>
              <li><i class="fa-solid fa-check"></i> Mensaje de bienvenida</li>
              <li><i class="fa-solid fa-check"></i> Mensaje fuera de horario</li>
              <li><i class="fa-solid fa-check"></i> Respuestas rápidas predefinidas</li>
              <li><i class="fa-solid fa-check"></i> Organización mediante etiquetas</li>
              <li><i class="fa-solid fa-check"></i> Carga de información de contacto</li>
              <li><i class="fa-solid fa-check"></i> Capacitación inicial de uso</li>
              <li><i class="fa-solid fa-check"></i> Soporte técnico básico</li>
            </ul>
          </div>
          
          <div class="pricing-results">
            <h5>Resultados Esperados</h5>
            <p><i class="fa-solid fa-bolt"></i> Responder más rápido</p>
            <p><i class="fa-solid fa-shield-halved"></i> Imagen comercial más profesional</p>
            <p><i class="fa-solid fa-clock"></i> No perder consultas fuera de horario</p>
          </div>
          
          <a href="/#contact" class="btn btn-secondary" style="margin-top: 1.5rem; justify-content: center; width: 100%;">Elegir Start</a>
        </div>

        <!-- CARD 2: ASC GROW (Destacado) -->
        <div class="glass-card pricing-card featured reveal" id="plan-grow" style="animation-delay: 0.1s;">
          <div class="pricing-badge">Popular</div>
          <div>
            <h3 style="font-size: 1.6rem; color: #fff;">ASC GROW</h3>
            <p style="font-size: 0.85rem; color: var(--text-muted); min-height: 48px; margin-top: 0.5rem;">
              Ideal para negocios que reciben consultas todos los días y necesitan organizar sus ventas.
            </p>
            
            <div class="price-value-container">
              <div class="price-setup">USD 300 Setup</div>
              <div class="price-monthly">USD 120<span>/mes</span></div>
            </div>
            
            <ul class="pricing-features">
              <li style="color: var(--primary); font-weight: 500;"><i class="fa-solid fa-plus" style="color: var(--primary);"></i> Incluye todo lo anterior más:</li>
              <li><i class="fa-solid fa-check"></i> Menú interactivo automatizado</li>
              <li><i class="fa-solid fa-check"></i> Derivación inteligente a humanos</li>
              <li><i class="fa-solid fa-check"></i> Captura automática de leads</li>
              <li><i class="fa-solid fa-check"></i> Clasificación automática de clientes</li>
              <li><i class="fa-solid fa-check"></i> Flujos lógicos personalizados</li>
              <li><i class="fa-solid fa-check"></i> Seguimiento básico de prospectos</li>
              <li><i class="fa-solid fa-check"></i> Métricas y estadísticas básicas</li>
              <li><i class="fa-solid fa-check"></i> Ajustes mensuales del flujo</li>
            </ul>
          </div>
          
          <div class="pricing-results">
            <h5>Resultados Esperados</h5>
            <p><i class="fa-solid fa-hourglass-half"></i> Ahorrar horas al responder</p>
            <p><i class="fa-solid fa-folder-open"></i> Organizar mejor los clientes</p>
            <p><i class="fa-solid fa-chart-line"></i> Convertir más consultas en ventas</p>
          </div>
          
          <a href="/#contact" class="btn btn-primary" style="margin-top: 1.5rem; justify-content: center; width: 100%;">Elegir Grow</a>
        </div>

        <!-- CARD 3: ASC AI (Destacado IA) -->
        <div class="glass-card pricing-card featured-ai reveal" id="plan-ai" style="animation-delay: 0.2s;">
          <div class="pricing-badge ai">IA Avanzada</div>
          <div>
            <h3 style="font-size: 1.6rem; color: #fff;">ASC AI</h3>
            <p style="font-size: 0.85rem; color: var(--text-muted); min-height: 48px; margin-top: 0.5rem;">
              Ideal para empresas que dependen de WhatsApp para vender y quieren automatizar procesos.
            </p>
            
            <div class="price-value-container">
              <div class="price-setup">USD 600 Setup</div>
              <div class="price-monthly">USD 250<span>/mes</span></div>
            </div>
            
            <ul class="pricing-features">
              <li style="color: var(--secondary); font-weight: 500;"><i class="fa-solid fa-plus" style="color: var(--secondary);"></i> Incluye todo lo anterior más:</li>
              <li><i class="fa-solid fa-check"></i> Automatizaciones de sistema avanzadas</li>
              <li><i class="fa-solid fa-check"></i> IA entrenada para preguntas frecuentes</li>
              <li><i class="fa-solid fa-check"></i> Hasta 500 chats de IA incluidos al mes</li>
              <li><i class="fa-solid fa-check"></i> Integración con CRM y sistemas externos</li>
              <li><i class="fa-solid fa-check"></i> Seguimientos automáticos de cotizaciones</li>
              <li><i class="fa-solid fa-check"></i> Reportes automatizados en PDF/Excel</li>
              <li><i class="fa-solid fa-check"></i> Base de datos de clientes integrada</li>
              <li><i class="fa-solid fa-check"></i> Soporte técnico prioritario 24/7</li>
            </ul>
          </div>
          
          <div class="pricing-results">
            <h5>Resultados Esperados</h5>
            <p><i class="fa-solid fa-circle-check"></i> Atención constante 24/7</p>
            <p><i class="fa-solid fa-robot"></i> Reducción extrema del trabajo manual</p>
            <p><i class="fa-solid fa-users-viewfinder"></i> Mayor tasa de conversión de leads</p>
            <p><i class="fa-solid fa-up-right-and-down-left-from-center"></i> Escalabilidad infinita de soporte</p>
          </div>
          
          <a href="/#contact" class="btn btn-secondary" style="margin-top: 1.5rem; justify-content: center; width: 100%; border-color: rgba(155, 81, 224, 0.4);">Elegir AI</a>
        </div>

      </div>
      
      <!-- AI Disclaimer Note -->
      <div class="reveal" style="max-width: 800px; margin: 3rem auto 0 auto; background: rgba(155, 81, 224, 0.04); border: 1px solid rgba(155, 81, 224, 0.15); padding: 1.5rem; border-radius: 16px; display: flex; gap: 1rem; align-items: flex-start;">
        <i class="fa-solid fa-circle-info" style="color: var(--secondary); font-size: 1.3rem; margin-top: 0.1rem;"></i>
        <div>
          <h4 style="font-size: 1rem; color: #fff; margin-bottom: 0.25rem;">Nota sobre el consumo de IA</h4>
          <p style="font-size: 0.85rem; color: var(--text-muted); line-height: 1.5;">
            Las 500 conversaciones mensuales con Inteligencia Artificial cubren ampliamente el volumen operativo regular de la mayoría de los negocios en crecimiento. Los consumos extraordinarios o las implementaciones avanzadas que requieran entrenamiento especial pueden generar cargos adicionales en la suscripción mensual.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Extras Section -->
  <section id="pricing-extras">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-subtitle">Personaliza tu Sistema</span>
        <h2 class="section-title">Extras y Módulos Adicionales</h2>
        <p class="section-desc">¿Necesitas funciones adicionales? Diseñamos componentes modulares para potenciar tu plan actual e integrarlos al instante.</p>
      </div>
      
      <div class="extras-grid">
        
        <!-- Extra 1: Landing Page -->
        <div class="extra-card reveal">
          <div class="extra-header">
            <h4 class="extra-title">Landing Page</h4>
            <span class="extra-price">USD 150</span>
          </div>
          <p class="extra-desc">Diseño de una página web profesional, optimizada para dispositivos móviles y equipada con formularios de contacto para capturar clientes potenciales.</p>
        </div>
        
        <!-- Extra 2: Agenda Online -->
        <div class="extra-card reveal" style="animation-delay: 0.05s;">
          <div class="extra-header">
            <h4 class="extra-title">Agenda Online</h4>
            <span class="extra-price">USD 100</span>
          </div>
          <p class="extra-desc">Calendario para reservas automáticas sincronizado directamente en el chat, con confirmaciones y recordatorios por WhatsApp.</p>
        </div>
        
        <!-- Extra 3: Seguimiento Automático -->
        <div class="extra-card reveal" style="animation-delay: 0.1s;">
          <div class="extra-header">
            <h4 class="extra-title">Seguimiento Automático</h4>
            <span class="extra-price">USD 100</span>
          </div>
          <p class="extra-desc">Envío automatizado de mensajes de seguimiento posterior a consultas para recuperar leads e incentivar conversiones.</p>
        </div>
        
        <!-- Extra 4: IA para Preguntas Frecuentes -->
        <div class="extra-card reveal" style="animation-delay: 0.15s;">
          <div class="extra-header">
            <h4 class="extra-title">IA para FAQs</h4>
            <span class="extra-price">USD 200</span>
          </div>
          <p class="extra-desc">Módulo conversacional autónomo para responder consultas frecuentes basado en la base de conocimientos de tu empresa (incluye 500 chats/mes).</p>
        </div>
        
        <!-- Extra 5: Google Sheets -->
        <div class="extra-card reveal" style="animation-delay: 0.2s;">
          <div class="extra-header">
            <h4 class="extra-title">Google Sheets</h4>
            <span class="extra-price">USD 100</span>
          </div>
          <p class="extra-desc">Guardado automático de contactos, consultas e historial de conversaciones directamente en una hoja de cálculo para auditoría y control.</p>
        </div>
        
        <!-- Extra 6: CRM -->
        <div class="extra-card reveal" style="animation-delay: 0.25s;">
          <div class="extra-header">
            <h4 class="extra-title">Integración con CRM</h4>
            <span class="extra-price">Desde USD 150</span>
          </div>
          <p class="extra-desc">Conexión de tus embudos de WhatsApp a CRMs corporativos como HubSpot, Zoho CRM, Salesforce y otros sistemas empresariales.</p>
        </div>
        
        <!-- Extra 7: Chat Web -->
        <div class="extra-card reveal" style="animation-delay: 0.3s;">
          <div class="extra-header">
            <h4 class="extra-title">Chat Web</h4>
            <span class="extra-price">USD 100</span>
          </div>
          <p class="extra-desc">Burbuja de chat flotante para integrar en tu sitio web corporativo, redirigiendo y enlazando de forma fluida a tu canal de WhatsApp.</p>
        </div>
        
        <!-- Extra 8: Campañas Masivas -->
        <div class="extra-card reveal" style="animation-delay: 0.35s;">
          <div class="extra-header">
            <h4 class="extra-title">Campañas Masivas</h4>
            <span class="extra-price">USD 100</span>
          </div>
          <p class="extra-desc">Configuración de herramientas para envíos masivos oficiales segmentando audiencias de clientes y enviando plantillas aprobadas por Meta.</p>
        </div>
        
        <!-- Extra 9: Encuestas Automáticas -->
        <div class="extra-card reveal" style="animation-delay: 0.4s;">
          <div class="extra-header">
            <h4 class="extra-title">Encuestas de WhatsApp</h4>
            <span class="extra-price">USD 75</span>
          </div>
          <p class="extra-desc">Solicitud de reseñas en Google/redes y encuestas de satisfacción automatizadas al finalizar compras o tickets de soporte.</p>
        </div>
        
        <!-- Extra 10: Recordatorios Automáticos -->
        <div class="extra-card reveal" style="animation-delay: 0.45s;">
          <div class="extra-header">
            <h4 class="extra-title">Recordatorios</h4>
            <span class="extra-price">USD 75</span>
          </div>
          <p class="extra-desc">Envío programado automático de recordatorios sobre turnos agendados, avisos de pagos pendientes y avisos de renovación de suscripciones.</p>
        </div>
        
        <!-- Extra 11: Cotizaciones Automáticas -->
        <div class="extra-card reveal" style="animation-delay: 0.5s;">
          <div class="extra-header">
            <h4 class="extra-title">Cotizaciones</h4>
            <span class="extra-price">USD 150</span>
          </div>
          <p class="extra-desc">Generación automática de cotizaciones personalizadas y presupuestos formales exportados a PDF y enviados de inmediato al chat.</p>
        </div>
        
        <!-- Extra 12: Panel de Métricas -->
        <div class="extra-card reveal" style="animation-delay: 0.55s;">
          <div class="extra-header">
            <h4 class="extra-title">Panel de Métricas</h4>
            <span class="extra-price">USD 200</span>
          </div>
          <p class="extra-desc">Dashboard de analítica que registra consultas recibidas, tiempos de respuesta de agentes, conversiones e historial de campañas.</p>
        </div>
        
        <!-- Extra 13: Base de Conocimiento -->
        <div class="extra-card reveal" style="animation-delay: 0.6s;">
          <div class="extra-header">
            <h4 class="extra-title">Base de Conocimiento</h4>
            <span class="extra-price">USD 150</span>
          </div>
          <p class="extra-desc">Carga inicial estructurada y entrenamiento de tus PDFs corporativos, archivos de preguntas frecuentes y documentos operativos en la base de datos de la IA.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Final CTA Section -->
  <section id="pricing-cta" style="background: linear-gradient(180deg, transparent, rgba(0, 242, 254, 0.01)); padding: 6rem 0;">
    <div class="container" style="text-align: center; max-width: 800px; display: flex; flex-direction: column; gap: 1.5rem;">
      <h2 style="font-size: 2.2rem; color: #fff;">¿Listo para automatizar tu negocio?</h2>
      <p style="color: var(--text-muted); font-size: 1.05rem;">Envíanos tu consulta sobre qué plan y adicionales requieres y te armamos un presupuesto cerrado adaptado a tu operativa.</p>
      <div style="margin-top: 1.5rem; display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap;">
        <a href="/#contact" class="btn btn-primary">Solicitar Plan Personalizado <i class="fa-solid fa-paper-plane"></i></a>
        <a href="https://wa.me/5491138927598" target="_blank" class="btn btn-secondary"><i class="fa-brands fa-whatsapp"></i> Chatear con Soporte</a>
      </div>
    </div>
  </section>
</Layout>
